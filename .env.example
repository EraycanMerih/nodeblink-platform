# Copy to .env on your machine or the DigitalOcean droplet — NEVER commit .env to git.

PORT=8080
PUBLIC_BASE_URL=https://api.nodeblink.dev
NEXT_PUBLIC_BASE_URL=https://nodeblink.dev
ASSET_BASE_URL=https://api.nodeblink.dev

# Supabase — use Session Pooler on DigitalOcean (IPv4). Replace REGION and YOUR_PASSWORD.
# Find pooler host in Supabase: Project Settings → Database → Connection string → Session pooler
DATABASE_URL=postgresql://postgres.ozthlvybyerymvyytknx:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?pgbouncer=true

# Direct connection — migrations / Prisma Studio only (not IPv4-safe on all networks)
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.ozthlvybyerymvyytknx.supabase.co:5432/postgres

SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PLATFORM_FEE_BPS=200
NODEBLINK_ENC_KEY=
TREASURY_WALLET=YOUR_TREASURY_WALLET_PUBKEY
DEFAULT_CREATOR_WALLET=YOUR_CREATOR_WALLET_PUBKEY
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_DECIMALS=6
