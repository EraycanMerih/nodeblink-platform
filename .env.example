# Example .env for NodeBlink (DO NOT COMMIT secrets to git)
PORT=8080
PUBLIC_BASE_URL=https://api.nodeblink.dev
ASSET_BASE_URL=https://api.nodeblink.dev
SOLANA_RPC_URL=
TREASURY_WALLET=11111111111111111111111111111111
DEFAULT_CREATOR_WALLET=11111111111111111111111111111111
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_DECIMALS=6
# SECURITY: provide a long random secret for download signing
DOWNLOAD_SECRET=your-32-byte-hex-or-base64-secret-here
# SECURITY: provide an ADMIN_SECRET for admin routes (do not store in public repo)
ADMIN_SECRET=replace-with-a-secure-secret
# Optional: restrict CORS origins
CORS_ORIGINS=https://your-frontend.example.com
# Optional: admin entry path
ADMIN_ENTRY_PATH=/operations-9b72f1c4d6e8
